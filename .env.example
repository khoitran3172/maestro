# === Maestro Environment Configuration ===

# Budget cap (USD). Maestro halts at 100%, warns at 80%.
MAX_USD=10.00

# === Specialist API Keys ===
# Claude (Anthropic) — used by Maestro core + Claude Code adapter
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used by Codex adapter
OPENAI_API_KEY=sk-...

# Grok Build — xAI
XAI_API_KEY=xai-...

# === Specialist CLI Paths (optional, defaults to PATH lookup) ===
# CLAUDE_CODE_CLI=claude
# CODEX_CLI=codex
# GROK_BUILD_CLI=grok
# ANTIGRAVITY_CLI=antigravity

# === Runtime Settings ===
# Max parallel specialist tasks (default: 3)
MAX_CONCURRENT_TASKS=3

# Default specialist timeout in seconds (default: 600)
DEFAULT_TIMEOUT_SEC=600

# Grading threshold (0-100). Below this = kick-back. (default: 75)
GRADE_THRESHOLD=75

# Max kick-back retries per task (default: 2)
MAX_RETRIES=2

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
